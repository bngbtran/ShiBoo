<Window x:Class="ShiBoo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ShiBoo System" Height="600" Width="900" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    </Grid.RowDefinitions>

        <Border x:Name="NavBar" Background="#2C3E50" Visibility="Collapsed" Padding="10">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button x:Name="BtnBack" Content="← Quay lại" Click="BtnBack_Click" 
        Background="Transparent" Foreground="White" BorderThickness="0" 
        Margin="0,0,20,0" Cursor="Hand" 
        Visibility="Collapsed"/>
                    <TextBlock x:Name="TxtTitle" Text="SHIBOO DASHBOARD" VerticalAlignment="Center" 
                               Foreground="White" FontWeight="Bold" FontSize="14"/>
                </StackPanel>

                <Button Content="Đăng xuất" Click="BtnLogout_Click" HorizontalAlignment="Right"
                        Background="#E74C3C" Foreground="White" Padding="15,5" BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>

        <ContentControl Grid.Row="1" x:Name="MainContent" />
    </Grid>
</Window>