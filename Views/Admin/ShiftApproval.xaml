<UserControl x:Class="ShiBoo.Views.Admin.ShiftApproval"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="QUẢN LÝ CA TRỰC &amp; DUYỆT ĐƠN" FontSize="20" FontWeight="Bold" Margin="10"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>   <ColumnDefinition Width="380"/> </Grid.ColumnDefinitions>

            <GroupBox Header="Gán ca trực mới" Grid.Column="0" Margin="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Chọn Nhân viên:"/>
                                <ComboBox x:Name="cbUserSuggest" Margin="0,5,0,10" IsEditable="True" 
                                          IsTextSearchEnabled="True" DisplayMemberPath="Name" 
                                          SelectedValuePath="Id" TextSearch.TextPath="Name"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Text="Chọn Ngày:"/>
                                <DatePicker x:Name="dpAssignDate" Margin="0,5,0,10"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Chọn Ca:"/>
                                <ComboBox x:Name="cbAssignShift" Margin="0,5,0,10">
                                    <ComboBoxItem Content="Ca 1" IsSelected="True"/>
                                    <ComboBoxItem Content="Ca 2"/>
                                    <ComboBoxItem Content="Ca 3"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <Button Content="Thực hiện Gán Ca" Click="BtnAssign_Click" 
                                Background="RoyalBlue" Foreground="White" Height="35" FontWeight="Bold"/>
                        
                        <Separator Margin="0,15"/>
                        <TextBlock Text="Danh sách tất cả ca trực chính thức:" FontWeight="Bold" Margin="0,0,0,5"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" x:Name="dgAllShifts" 
          AutoGenerateColumns="False" 
          CanUserAddRows="False"
          CellEditEnding="dgAllShifts_CellEditEnding"
          Margin="10,0,10,10">

    <DataGrid.Columns>
        <DataGridTextColumn Header="Nhân viên" Binding="{Binding UserName}" Width="*"/>
        <DataGridTextColumn Header="Ngày" Binding="{Binding Date, StringFormat=\{0:dd/MM\}}" Width="60"/>
        
        <DataGridTemplateColumn Header="Ca" Width="100">
            <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding ShiftName}" VerticalAlignment="Center" Margin="5,0"/>
                </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
            <DataGridTemplateColumn.CellEditingTemplate>
                <DataTemplate>
                    <ComboBox Text="{Binding ShiftName, UpdateSourceTrigger=PropertyChanged}" 
                              IsDropDownOpen="True">
                        <ComboBoxItem Content="Ca 1"/>
                        <ComboBoxItem Content="Ca 2"/>
                        <ComboBoxItem Content="Ca 3"/>
                    </ComboBox>
                </DataTemplate>
            </DataGridTemplateColumn.CellEditingTemplate>
        </DataGridTemplateColumn>

        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
        
        <DataGridTemplateColumn Width="60">
            <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                    <Button Content="Xóa" Click="BtnDeleteShift_Click" Background="Gray" Foreground="White" FontSize="10"/>
                </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
    </DataGrid.Columns>
</DataGrid>
                </Grid>
            </GroupBox>

            <GroupBox Header="Đơn chờ duyệt &amp; Sửa" Grid.Column="1" Margin="5">
                <DataGrid x:Name="dgPendingShifts" AutoGenerateColumns="False" CanUserAddRows="False">
    <DataGrid.Columns>
        <DataGridTextColumn Header="NV" Binding="{Binding UserName}" Width="*"/>
        <DataGridTextColumn Header="Ngày" Binding="{Binding Date, StringFormat=\{0:dd/MM\}}" Width="55"/>
        
        <DataGridTextColumn Header="Ca cũ" Binding="{Binding ShiftName}" Width="60"/>
        
        <DataGridTextColumn Header="Ca muốn đổi" Binding="{Binding Note}" FontWeight="Bold" Foreground="Red" Width="80"/>

        <DataGridTemplateColumn Header="Lệnh" Width="110">
            <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Duyệt" Click="BtnApprove_Click" Background="Green" Foreground="White" Margin="2"/>
                        <Button Content="Từ chối" Click="BtnReject_Click" Background="Red" Foreground="White" Margin="2"/>
                    </StackPanel>
                </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
    </DataGrid.Columns>
</DataGrid>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>