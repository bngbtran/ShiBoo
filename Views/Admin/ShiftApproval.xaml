<UserControl x:Class="ShiBoo.Views.Admin.ShiftApproval"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0F172A">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="Quản lý ca trực &amp; duyệt đơn"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="White"
                   Margin="5"/>

        <Grid Grid.Row="1" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT CARD -->
            <Border Background="White"
                    CornerRadius="12"
                    Padding="15"
                    Margin="5">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- FORM -->
                    <StackPanel Grid.Row="0">

                        <TextBlock Text="Gán ca trực"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <!-- User -->
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Nhân viên"/>
                                <ComboBox x:Name="cbUserSuggest"
                                          Height="32"
                                          Background="#F1F5F9"
                                          BorderThickness="0"
                                          IsEditable="True"
                                          DisplayMemberPath="Name"/>
                            </StackPanel>

                            <!-- Date -->
                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Text="Ngày"/>
                                <DatePicker x:Name="dpAssignDate"
                                            Height="32"
                                            Background="#F1F5F9"/>
                            </StackPanel>

                            <!-- Shift -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Ca"/>
                                <ComboBox x:Name="cbAssignShift"
                                          Height="32"
                                          Background="#F1F5F9"
                                          BorderThickness="0">
                                    <ComboBoxItem Content="Ca 1"/>
                                    <ComboBoxItem Content="Ca 2"/>
                                    <ComboBoxItem Content="Ca 3"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <Button Content="Gán ca"
                                Click="BtnAssign_Click"
                                Height="36"
                                Margin="0,10,0,10"
                                Background="#1E3A8A"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"/>

                        <TextBlock Text="Danh sách ca trực"
                                   FontWeight="Bold"
                                   Margin="0,10,0,5"/>

                    </StackPanel>

                    <!-- DATAGRID -->
                    <DataGrid Grid.Row="1"
                              x:Name="dgAllShifts"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              Margin="0,5,0,0"
                              RowHeight="35"
                              HeadersVisibility="Column">

                        <DataGrid.Resources>
                            <!-- Header style -->
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#E2E8F0"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nhân viên" Binding="{Binding UserName}" Width="*"/>
                            <DataGridTextColumn Header="Ngày" Binding="{Binding Date, StringFormat=\{0:dd/MM\}}" Width="80"/>
                            <DataGridTextColumn Header="Ca" Binding="{Binding ShiftName}" Width="80"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>

                            <DataGridTemplateColumn Width="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Xóa"
                                                Click="BtnDeleteShift_Click"
                                                Background="#64748B"
                                                Foreground="White"
                                                FontSize="11"
                                                Padding="5,2"
                                                BorderThickness="0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- RIGHT CARD -->
            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="12"
                    Padding="15"
                    Margin="5">

                <StackPanel>
                    <TextBlock Text="Đơn chờ duyệt"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <DataGrid x:Name="dgPendingShifts"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              RowHeight="35">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nhân viên" Binding="{Binding UserName}" Width="70"/>
                            <DataGridTextColumn Header="Ngày" Binding="{Binding Date, StringFormat=\{0:dd/MM\}}" Width="70"/>
                            <DataGridTextColumn Header="Ca cũ" Binding="{Binding ShiftName}" Width="70"/>

                            <DataGridTextColumn Header="Ca đổi"
                                                Binding="{Binding Note}"
                                                Width="80"
                                                Foreground="Red"
                                                FontWeight="Bold"/>

                            <DataGridTemplateColumn Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="✔"
                                                    Click="BtnApprove_Click"
                                                    Background="#16A34A"
                                                    Foreground="White"
                                                    Margin="2"
                                                    Width="40"/>

                                            <Button Content="✖"
                                                    Click="BtnReject_Click"
                                                    Background="#DC2626"
                                                    Foreground="White"
                                                    Margin="2"
                                                    Width="40"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</UserControl>