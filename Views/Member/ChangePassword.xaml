<UserControl x:Class="ShiBoo.Views.Member.ChangePassword"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
            <TextBlock Text="ĐỔI MẬT KHẨU LẦN ĐẦU" FontSize="16" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>
            
            <TextBlock Text="Mật khẩu mới:"/>
            <PasswordBox x:Name="txtNewPass" Margin="0,5,0,20" Height="30"/>
            
            <Button Content="Cập nhật mật khẩu" Click="BtnUpdate_Click" 
                    Height="35" Background="DarkGreen" Foreground="White"/>
        </StackPanel>
    </Grid>
</UserControl>