<UserControl x:Class="ShiBoo.Views.Member.ChangePassword"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0F172A">

    <Grid>
        <Border Background="White"
                Width="360"
                Padding="30"
                CornerRadius="12"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <StackPanel>

                <!-- Title -->
                <TextBlock Text="Đổi mật khẩu"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#0F172A"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Vui lòng cập nhật mật khẩu mới để tiếp tục"
                           FontSize="13"
                           Foreground="Gray"
                           TextAlignment="Center"
                           Margin="0,5,0,20"/>

                <!-- New Password -->
                <TextBlock Text="Mật khẩu mới"
                           FontWeight="SemiBold"/>

                <PasswordBox x:Name="txtNewPass"
                             Height="35"
                             Margin="0,5,0,15"
                             Padding="8"
                             Background="#F1F5F9"
                             BorderThickness="0"/>

                <!-- Confirm Password -->
                <TextBlock Text="Nhập lại mật khẩu"
                           FontWeight="SemiBold"/>

                <PasswordBox x:Name="txtConfirmPass"
                             Height="35"
                             Margin="0,5,0,20"
                             Padding="8"
                             Background="#F1F5F9"
                             BorderThickness="0"/>

                <!-- Button -->
                <Button Content="Cập nhật mật khẩu"
                        Click="BtnUpdate_Click"
                        Height="40"
                        Background="#1E3A8A"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1D4ED8"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#1E40AF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>

                </Button>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>