<UserControl x:Class="ShiBoo.Views.Member.PersonalShift"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ShiBoo.Helpers"
             Background="#0F172A">

    <UserControl.Resources>
        <conv:ShiftDisableConverter x:Key="ShiftDisableConverter"/>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="White"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,20">

            <StackPanel>
                <TextBlock Text="Đăng ký ca trực"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal">

                    <DatePicker x:Name="dpRequestDate"
                                Width="150"
                                Height="32"
                                Background="#F1F5F9"
                                Margin="0,0,10,0"/>

                    <ComboBox x:Name="cbRequestShift"
                              Width="150"
                              Height="32"
                              Background="#F1F5F9"
                              BorderThickness="0"
                              Margin="0,0,10,0">
                        <ComboBoxItem Content="Ca 1"/>
                        <ComboBoxItem Content="Ca 2"/>
                        <ComboBoxItem Content="Ca 3"/>
                    </ComboBox>

                    <Button Content="Gửi yêu cầu"
                            Click="BtnRequest_Click"
                            Padding="12,4"
                            Background="#1E3A8A"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="10">

            <StackPanel>
                <TextBlock Text="Lịch trực của tôi"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="5"/>

                <DataGrid x:Name="dgMyShifts"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          RowHeight="35"
                          HeadersVisibility="Column">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#E2E8F0"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ngày"
                                            Binding="{Binding Date, StringFormat=\{0:dd/MM/yyyy\}}"
                                            Width="140"/>

                        <DataGridTextColumn Header="Ca hiện tại"
                                            Binding="{Binding ShiftName}"
                                            Width="120"/>

                        <DataGridTextColumn Header="Trạng thái"
                                            Binding="{Binding Status}"
                                            Width="120"/>

                        <DataGridTemplateColumn Header="Đổi ca"
                                                Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">

                                        <ComboBox x:Name="cbNewShift"
                                                  Width="110"
                                                  Margin="2"
                                                  SelectedValuePath="Content"
                                                  Loaded="cbNewShift_Loaded">

                                            <ComboBoxItem Content="Ca 1">
                                                <ComboBoxItem.IsEnabled>
                                                    <MultiBinding Converter="{StaticResource ShiftDisableConverter}">
                                                        <Binding Source="Ca 1"/>
                                                        <Binding Path="ShiftName"/>
                                                    </MultiBinding>
                                                </ComboBoxItem.IsEnabled>
                                            </ComboBoxItem>

                                            <ComboBoxItem Content="Ca 2">
                                                <ComboBoxItem.IsEnabled>
                                                    <MultiBinding Converter="{StaticResource ShiftDisableConverter}">
                                                        <Binding Source="Ca 2"/>
                                                        <Binding Path="ShiftName"/>
                                                    </MultiBinding>
                                                </ComboBoxItem.IsEnabled>
                                            </ComboBoxItem>

                                            <ComboBoxItem Content="Ca 3">
                                                <ComboBoxItem.IsEnabled>
                                                    <MultiBinding Converter="{StaticResource ShiftDisableConverter}">
                                                        <Binding Source="Ca 3"/>
                                                        <Binding Path="ShiftName"/>
                                                    </MultiBinding>
                                                </ComboBoxItem.IsEnabled>
                                            </ComboBoxItem>

                                        </ComboBox>

                                        <Button Content="Đổi"
                                                Click="BtnEditRequest_Click"
                                                Background="#F59E0B"
                                                Foreground="White"
                                                Padding="8,2"
                                                Margin="5,0"
                                                BorderThickness="0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>